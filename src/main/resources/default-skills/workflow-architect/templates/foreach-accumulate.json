{
  "id": null,
  "name": "Fetch List Then Detail Per Item",
  "version": "1",
  "packageId": null,
  "description": "Linear fan-out pattern: fetch a list, foreach item fetch its detail, accumulate the details into a single output list, then end. Replace tool names and item key with the real ones.",
  "variables": [
    {
      "name": "apiParams",
      "javaClass": "java.util.Map",
      "defaultExpression": "{}",
      "required": false
    },
    {
      "name": "items",
      "javaClass": "java.util.List",
      "defaultExpression": null,
      "required": false
    },
    {
      "name": "currentItem",
      "javaClass": "java.util.Map",
      "defaultExpression": null,
      "required": false
    },
    {
      "name": "currentIndex",
      "javaClass": "java.lang.Long",
      "defaultExpression": "0",
      "required": false
    },
    {
      "name": "itemDetail",
      "javaClass": "java.util.Map",
      "defaultExpression": null,
      "required": false
    },
    {
      "name": "details",
      "javaClass": "java.util.Map",
      "defaultExpression": null,
      "required": false
    }
  ],
  "activities": [
    {
      "id": "start",
      "name": "Start",
      "type": "route",
      "pluginName": null,
      "properties": {},
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": null,
      "isStart": true,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [],
      "andJoin": false,
      "errorPolicy": { "retryCount": 0, "backoffMs": 0, "timeoutMs": null, "failFast": false, "continueOnError": false }
    },
    {
      "id": "fetchList",
      "name": "Fetch List",
      "type": "tool",
      "pluginName": "AgentToolPlugin",
      "properties": { "toolName": "list_items_tool", "input": "#{#apiParams}" },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": "PT30S",
      "isStart": false,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [
        { "name": "items", "javaClass": "java.util.List", "defaultExpression": null, "required": false }
      ],
      "andJoin": false,
      "errorPolicy": { "retryCount": 2, "backoffMs": 500, "timeoutMs": 15000, "failFast": false, "continueOnError": false }
    },
    {
      "id": "iterate",
      "name": "For each item",
      "type": "foreach",
      "pluginName": null,
      "properties": {
        "collection": "#{#items}",
        "itemVar": "currentItem",
        "indexVar": "currentIndex",
        "maxIterations": 1000
      },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": null,
      "isStart": false,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [],
      "andJoin": false,
      "errorPolicy": { "retryCount": 0, "backoffMs": 0, "timeoutMs": null, "failFast": false, "continueOnError": false }
    },
    {
      "id": "fetchDetail",
      "name": "Fetch Item Detail",
      "type": "tool",
      "pluginName": "AgentToolPlugin",
      "properties": { "toolName": "detail_by_id_tool", "input": "#{#currentItem.id}" },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": "PT15S",
      "isStart": false,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [
        { "name": "itemDetail", "javaClass": "java.util.Map", "defaultExpression": null, "required": false }
      ],
      "andJoin": false,
      "errorPolicy": { "retryCount": 1, "backoffMs": 250, "timeoutMs": 10000, "failFast": false, "continueOnError": true }
    },
    {
      "id": "accumulate",
      "name": "Accumulate Detail",
      "type": "tool",
      "pluginName": "CodeExecPlugin",
      "properties": {
        "language": "java",
        "code": "java.util.List<Object> acc = new java.util.ArrayList<>();\nif (input.get(\"acc\") instanceof java.util.List<?> existing) {\n    for (Object o : existing) acc.add(o);\n}\nObject item = input.get(\"item\");\nif (item != null) acc.add(item);\nreturn acc;",
        "input": "#{ {'acc': #details?.output, 'item': #itemDetail} }",
        "timeoutMs": 5000,
        "memoryLimitMb": 64
      },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": "PT10S",
      "isStart": false,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [
        { "name": "details", "javaClass": "java.util.List", "defaultExpression": null, "required": false }
      ],
      "andJoin": false,
      "errorPolicy": { "retryCount": 1, "backoffMs": 200, "timeoutMs": 5000, "failFast": false, "continueOnError": false }
    },
    {
      "id": "end",
      "name": "End",
      "type": "route",
      "pluginName": null,
      "properties": { "result": "#{#details?.output}" },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": null,
      "isStart": false,
      "isEnd": true,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [],
      "andJoin": false,
      "errorPolicy": { "retryCount": 0, "backoffMs": 0, "timeoutMs": null, "failFast": false, "continueOnError": false }
    }
  ],
  "transitions": [
    { "id": "t-start-fetchList",   "fromActivityId": "start",       "toActivityId": "fetchList",   "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",   "priority": null, "isDefault": false },
    { "id": "t-fetchList-iterate", "fromActivityId": "fetchList",   "toActivityId": "iterate",     "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",   "priority": null, "isDefault": false },
    { "id": "t-fetchList-err-end", "fromActivityId": "fetchList",   "toActivityId": "end",         "condition": null, "isErrorEdge": true,  "matchesErrorClass": null, "trigger": "ON_ERROR",     "priority": 1,    "isDefault": false },
    { "id": "t-iterate-body",      "fromActivityId": "iterate",     "toActivityId": "fetchDetail", "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",   "priority": null, "isDefault": false },
    { "id": "t-iterate-end",       "fromActivityId": "iterate",     "toActivityId": "end",         "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_NO_MATCH",  "priority": 100,  "isDefault": true },
    { "id": "t-fetchDetail-acc",   "fromActivityId": "fetchDetail", "toActivityId": "accumulate",  "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",   "priority": null, "isDefault": false },
    { "id": "t-accumulate-loop",   "fromActivityId": "accumulate",  "toActivityId": "iterate",     "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",   "priority": null, "isDefault": false }
  ]
}
