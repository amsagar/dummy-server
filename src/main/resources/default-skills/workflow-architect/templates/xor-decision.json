{
  "id": null,
  "name": "XOR Decision Workflow",
  "version": "1",
  "packageId": null,
  "description": "Run a tool, then branch on its boolean result via a route activity with two conditioned outgoing transitions.",
  "variables": [
    { "name": "subjectId", "javaClass": "java.lang.String", "defaultExpression": null, "required": true }
  ],
  "activities": [
    {
      "id": "start", "name": "Start", "type": "route", "pluginName": null,
      "properties": {}, "deadlineExpression": null,
      "isStart": true, "isEnd": false,
      "subflowDefId": null, "subflowInputs": {}, "subflowOutputs": {},
      "outputVariables": [], "andJoin": false
    },
    {
      "id": "evaluate", "name": "Evaluate", "type": "tool", "pluginName": "AgentToolPlugin",
      "properties": { "toolName": "evaluate_subject", "input": "#{#subjectId}" },
      "deadlineExpression": null,
      "isStart": false, "isEnd": false,
      "subflowDefId": null, "subflowInputs": {}, "subflowOutputs": {},
      "outputVariables": [
        { "name": "decision", "javaClass": "java.util.Map", "defaultExpression": null, "required": false }
      ],
      "andJoin": false
    },
    {
      "id": "decide", "name": "Decide", "type": "route", "pluginName": null,
      "properties": {}, "deadlineExpression": null,
      "isStart": false, "isEnd": false,
      "subflowDefId": null, "subflowInputs": {}, "subflowOutputs": {},
      "outputVariables": [], "andJoin": false
    },
    {
      "id": "approve", "name": "Approve Path", "type": "tool", "pluginName": "AgentToolPlugin",
      "properties": { "toolName": "approve_subject", "input": "#{#subjectId}" },
      "deadlineExpression": null,
      "isStart": false, "isEnd": false,
      "subflowDefId": null, "subflowInputs": {}, "subflowOutputs": {},
      "outputVariables": [], "andJoin": false
    },
    {
      "id": "reject", "name": "Reject Path", "type": "tool", "pluginName": "AgentToolPlugin",
      "properties": { "toolName": "reject_subject", "input": "#{#subjectId}" },
      "deadlineExpression": null,
      "isStart": false, "isEnd": false,
      "subflowDefId": null, "subflowInputs": {}, "subflowOutputs": {},
      "outputVariables": [], "andJoin": false
    },
    {
      "id": "end", "name": "End", "type": "route", "pluginName": null,
      "properties": {}, "deadlineExpression": null,
      "isStart": false, "isEnd": true,
      "subflowDefId": null, "subflowInputs": {}, "subflowOutputs": {},
      "outputVariables": [], "andJoin": false
    }
  ],
  "transitions": [
    { "id": "t1", "fromActivityId": "start",    "toActivityId": "evaluate", "condition": null,                       "isErrorEdge": false, "matchesErrorClass": null },
    { "id": "t2", "fromActivityId": "evaluate", "toActivityId": "decide",   "condition": null,                       "isErrorEdge": false, "matchesErrorClass": null },
    { "id": "t3", "fromActivityId": "decide",   "toActivityId": "approve",  "condition": "#decision.approved == true", "isErrorEdge": false, "matchesErrorClass": null },
    { "id": "t4", "fromActivityId": "decide",   "toActivityId": "reject",   "condition": "#decision.approved != true", "isErrorEdge": false, "matchesErrorClass": null },
    { "id": "t5", "fromActivityId": "approve",  "toActivityId": "end",      "condition": null,                       "isErrorEdge": false, "matchesErrorClass": null },
    { "id": "t6", "fromActivityId": "reject",   "toActivityId": "end",      "condition": null,                       "isErrorEdge": false, "matchesErrorClass": null }
  ]
}
