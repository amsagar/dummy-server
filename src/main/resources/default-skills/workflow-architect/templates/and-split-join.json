{
  "id": null,
  "name": "Parallel Tools With AND-Join",
  "version": "1",
  "packageId": null,
  "description": "Two independent tools fan out from start; both must complete before the join activity proceeds (andJoin=true).",
  "variables": [
    { "name": "query", "javaClass": "java.lang.String", "defaultExpression": null, "required": true }
  ],
  "activities": [
    {
      "id": "start", "name": "Start", "type": "route", "pluginName": null,
      "properties": {}, "deadlineExpression": null,
      "isStart": true, "isEnd": false,
      "subflowDefId": null, "subflowInputs": {}, "subflowOutputs": {},
      "outputVariables": [], "andJoin": false
    },
    {
      "id": "fetchA", "name": "Fetch Source A", "type": "tool", "pluginName": "AgentToolPlugin",
      "properties": { "toolName": "search_source_a", "input": "#{#query}" },
      "deadlineExpression": null,
      "isStart": false, "isEnd": false,
      "subflowDefId": null, "subflowInputs": {}, "subflowOutputs": {},
      "outputVariables": [
        { "name": "resultA", "javaClass": "java.util.Map", "defaultExpression": null, "required": false }
      ],
      "andJoin": false
    },
    {
      "id": "fetchB", "name": "Fetch Source B", "type": "tool", "pluginName": "AgentToolPlugin",
      "properties": { "toolName": "search_source_b", "input": "#{#query}" },
      "deadlineExpression": null,
      "isStart": false, "isEnd": false,
      "subflowDefId": null, "subflowInputs": {}, "subflowOutputs": {},
      "outputVariables": [
        { "name": "resultB", "javaClass": "java.util.Map", "defaultExpression": null, "required": false }
      ],
      "andJoin": false
    },
    {
      "id": "join", "name": "Join", "type": "route", "pluginName": null,
      "properties": {}, "deadlineExpression": null,
      "isStart": false, "isEnd": false,
      "subflowDefId": null, "subflowInputs": {}, "subflowOutputs": {},
      "outputVariables": [],
      "andJoin": true
    },
    {
      "id": "end", "name": "End", "type": "route", "pluginName": null,
      "properties": { "result": "#{ {'a': #resultA, 'b': #resultB} }" }, "deadlineExpression": null,
      "isStart": false, "isEnd": true,
      "subflowDefId": null, "subflowInputs": {}, "subflowOutputs": {},
      "outputVariables": [], "andJoin": false
    }
  ],
  "transitions": [
    { "id": "t1", "fromActivityId": "start",  "toActivityId": "fetchA", "condition": null, "isErrorEdge": false, "matchesErrorClass": null },
    { "id": "t2", "fromActivityId": "start",  "toActivityId": "fetchB", "condition": null, "isErrorEdge": false, "matchesErrorClass": null },
    { "id": "t3", "fromActivityId": "fetchA", "toActivityId": "join",   "condition": null, "isErrorEdge": false, "matchesErrorClass": null },
    { "id": "t4", "fromActivityId": "fetchB", "toActivityId": "join",   "condition": null, "isErrorEdge": false, "matchesErrorClass": null },
    { "id": "t5", "fromActivityId": "join",   "toActivityId": "end",    "condition": null, "isErrorEdge": false, "matchesErrorClass": null }
  ]
}
