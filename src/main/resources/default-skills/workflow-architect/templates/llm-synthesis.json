{
  "id": null,
  "name": "Tools With LLM Synthesis",
  "version": "1",
  "packageId": null,
  "description": "Run a deterministic tool to gather data, then call an LLM to synthesize a final answer.",
  "variables": [
    { "name": "userQuestion", "javaClass": "java.lang.String", "defaultExpression": null, "required": true }
  ],
  "activities": [
    {
      "id": "start", "name": "Start", "type": "route", "pluginName": null,
      "properties": {}, "deadlineExpression": null,
      "isStart": true, "isEnd": false,
      "subflowDefId": null, "subflowInputs": {}, "subflowOutputs": {},
      "outputVariables": [], "andJoin": false
    },
    {
      "id": "search", "name": "Search Knowledge", "type": "tool", "pluginName": "AgentToolPlugin",
      "properties": { "toolName": "knowledge_search", "input": "#{#userQuestion}" },
      "deadlineExpression": null,
      "isStart": false, "isEnd": false,
      "subflowDefId": null, "subflowInputs": {}, "subflowOutputs": {},
      "outputVariables": [
        { "name": "searchResults", "javaClass": "java.util.Map", "defaultExpression": null, "required": false }
      ],
      "andJoin": false
    },
    {
      "id": "synthesize", "name": "Synthesize Answer", "type": "tool", "pluginName": "AiChatPlugin",
      "properties": {
        "provider": "anthropic",
        "model":    "claude-sonnet-4-6",
        "system":   "You answer the user's question using only the provided context. Cite results when relevant.",
        "prompt":   "#{'Question: ' + #userQuestion + '\\n\\nContext:\\n' + #searchResults}"
      },
      "deadlineExpression": "PT60S",
      "isStart": false, "isEnd": false,
      "subflowDefId": null, "subflowInputs": {}, "subflowOutputs": {},
      "outputVariables": [
        { "name": "answer", "javaClass": "java.lang.String", "defaultExpression": null, "required": false }
      ],
      "andJoin": false
    },
    {
      "id": "end", "name": "End", "type": "route", "pluginName": null,
      "properties": {}, "deadlineExpression": null,
      "isStart": false, "isEnd": true,
      "subflowDefId": null, "subflowInputs": {}, "subflowOutputs": {},
      "outputVariables": [], "andJoin": false
    }
  ],
  "transitions": [
    { "id": "t1", "fromActivityId": "start",      "toActivityId": "search",     "condition": null, "isErrorEdge": false, "matchesErrorClass": null },
    { "id": "t2", "fromActivityId": "search",     "toActivityId": "synthesize", "condition": null, "isErrorEdge": false, "matchesErrorClass": null },
    { "id": "t3", "fromActivityId": "synthesize", "toActivityId": "end",        "condition": null, "isErrorEdge": false, "matchesErrorClass": null }
  ]
}
