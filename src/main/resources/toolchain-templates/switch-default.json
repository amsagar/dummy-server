{
  "name": "Switch With Default",
  "description": "Switch case routing with default fallback.",
  "graph": {
    "nodes": [
      { "id": "start", "type": "start", "label": "Start", "config": {} },
      { "id": "switch_1", "type": "switch", "label": "Country Switch", "config": { "sourceKey": "$.chainInput.country", "default": "fallback", "cases": [ { "when": "US", "to": "us_path" }, { "whenExpression": "$.chainInput.country == \"UK\"", "to": "uk_path" } ] } },
      { "id": "us_path", "type": "tool", "label": "US", "config": { "toolName": "us_handler" } },
      { "id": "uk_path", "type": "tool", "label": "UK", "config": { "toolName": "uk_handler" } },
      { "id": "fallback", "type": "tool", "label": "Fallback", "config": { "toolName": "fallback_handler" } },
      { "id": "end", "type": "end", "label": "End", "config": {} }
    ],
    "edges": [
      { "from": "start", "to": "switch_1" },
      { "from": "switch_1", "to": "us_path" },
      { "from": "switch_1", "to": "uk_path" },
      { "from": "switch_1", "to": "fallback" },
      { "from": "us_path", "to": "end" },
      { "from": "uk_path", "to": "end" },
      { "from": "fallback", "to": "end" }
    ]
  }
}
