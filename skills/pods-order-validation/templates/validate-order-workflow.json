{
  "id": null,
  "name": "Validate Pods Order",
  "version": "1",
  "packageId": null,
  "description": "Validates a PODS order across leg sequence, serviceability, and container availability. Fetch order -> prepare leg lines (sort by Sequence, map ItemCode->ServiceCode) -> evaluate Leg Sequences decision table -> foreach leg line call Serviceability -> filter IDEL lines needing container check -> foreach call ContainerAvailability -> return aggregated result. This is a structural skeleton; edit field values for the order under test, but do NOT delete activities or change the foreach wiring.",
  "variables": [
    { "name": "orderId",                       "javaClass": "java.lang.String",  "defaultExpression": null, "required": true  },
    { "name": "order",                         "javaClass": "java.util.Map",     "defaultExpression": null, "required": false },
    { "name": "legLines",                      "javaClass": "java.util.List",    "defaultExpression": null, "required": false },
    { "name": "actualSequence",                "javaClass": "java.util.List",    "defaultExpression": null, "required": false },
    { "name": "journeyType",                   "javaClass": "java.lang.String",  "defaultExpression": null, "required": false },
    { "name": "legSequenceResult",             "javaClass": "java.util.Map",     "defaultExpression": null, "required": false },
    { "name": "currentLegLine",                "javaClass": "java.util.Map",     "defaultExpression": null, "required": false },
    { "name": "currentLegIndex",               "javaClass": "java.lang.Long",    "defaultExpression": "0",  "required": false },
    { "name": "serviceabilityResult",          "javaClass": "java.util.Map",     "defaultExpression": null, "required": false },
    { "name": "serviceabilityResults",         "javaClass": "java.util.List",    "defaultExpression": null, "required": false },
    { "name": "toCheck",                       "javaClass": "java.util.List",    "defaultExpression": null, "required": false },
    { "name": "currentContainerLine",          "javaClass": "java.util.Map",     "defaultExpression": null, "required": false },
    { "name": "currentContainerIndex",         "javaClass": "java.lang.Long",    "defaultExpression": "0",  "required": false },
    { "name": "containerAvailabilityResult",   "javaClass": "java.util.Map",     "defaultExpression": null, "required": false },
    { "name": "containerAvailabilityResults",  "javaClass": "java.util.List",    "defaultExpression": null, "required": false }
  ],
  "activities": [
    {
      "id": "start",
      "name": "Start",
      "type": "route",
      "pluginName": null,
      "properties": {},
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": null,
      "isStart": true,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [],
      "andJoin": false,
      "errorPolicy": { "retryCount": 0, "backoffMs": 0, "timeoutMs": null, "failFast": false, "continueOnError": false }
    },
    {
      "id": "fetchOrder",
      "name": "Fetch Order",
      "type": "tool",
      "pluginName": "AgentToolPlugin",
      "properties": { "toolName": "Get_OrderID", "input": "#{ {'ORD_ID': #orderId} }" },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": "PT30S",
      "isStart": false,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [
        { "name": "order", "javaClass": "java.util.Map", "defaultExpression": null, "required": false }
      ],
      "andJoin": false,
      "errorPolicy": { "retryCount": 2, "backoffMs": 500, "timeoutMs": 15000, "failFast": false, "continueOnError": false }
    },
    {
      "id": "prepareLegLines",
      "name": "Prepare Leg Lines (filter + sort + map service codes)",
      "type": "tool",
      "pluginName": "CodeExecPlugin",
      "properties": {
        "language": "java",
        "code": "// Step 2 + 3 of the pods-order-validation skill.\n// 1) Filter order.Lines on VALID_ITEM_CODES (read ItemCode, NOT ServiceCode).\n// 2) Sort by Sequence ASC.\n// 3) Build actualSequence using line.ServiceCode if non-empty,\n//    else fall back to ITEM_TO_SERVICE mapping for that ItemCode.\n// Returns { legLines, actualSequence, journeyType } for downstream steps.\njava.util.Set<String> VALID_ITEM_CODES = java.util.Set.of(\n    \"IDEL\",\"RETSC\",\"LDT\",\"REDEL\",\"FPU\",\"MOV\",\"SID\",\"SFP\",\"SCDEL\",\"CSRED\",\"CSFPU\");\njava.util.Map<String,String> ITEM_TO_SERVICE = java.util.Map.ofEntries(\n    java.util.Map.entry(\"IDEL\",\"NEW\"), java.util.Map.entry(\"RETSC\",\"WRT\"),\n    java.util.Map.entry(\"LDT\",\"WTW\"),  java.util.Map.entry(\"REDEL\",\"RDL\"),\n    java.util.Map.entry(\"FPU\",\"FPU\"),  java.util.Map.entry(\"MOV\",\"MOV\"),\n    java.util.Map.entry(\"SID\",\"SID\"),  java.util.Map.entry(\"SFP\",\"SFP\"),\n    java.util.Map.entry(\"SCDEL\",\"SCDEL\"), java.util.Map.entry(\"CSRED\",\"CSRED\"),\n    java.util.Map.entry(\"CSFPU\",\"CSFPU\"));\njava.util.Map<String,Object> order = (java.util.Map<String,Object>) input.get(\"order\");\njava.util.List<java.util.Map<String,Object>> allLines =\n    (java.util.List<java.util.Map<String,Object>>) order.getOrDefault(\"Lines\", java.util.List.of());\njava.util.List<java.util.Map<String,Object>> legs = new java.util.ArrayList<>();\nfor (java.util.Map<String,Object> l : allLines) {\n  Object ic = l.get(\"ItemCode\");\n  if (ic != null && VALID_ITEM_CODES.contains(ic.toString())) legs.add(l);\n}\nlegs.sort((a,b) -> {\n  Number sa = (Number) a.getOrDefault(\"Sequence\", 0);\n  Number sb = (Number) b.getOrDefault(\"Sequence\", 0);\n  return Long.compare(sa.longValue(), sb.longValue());\n});\njava.util.List<String> seq = new java.util.ArrayList<>();\nfor (java.util.Map<String,Object> l : legs) {\n  Object svc = l.get(\"ServiceCode\");\n  String s = (svc != null && !svc.toString().isBlank())\n      ? svc.toString()\n      : ITEM_TO_SERVICE.get(String.valueOf(l.get(\"ItemCode\")));\n  if (s != null) seq.add(s);\n}\njava.util.Map<String,Object> out = new java.util.LinkedHashMap<>();\nout.put(\"legLines\", legs);\nout.put(\"actualSequence\", seq);\nout.put(\"journeyType\", String.valueOf(order.getOrDefault(\"OrderType\", \"\")));\nreturn out;",
        "input": "#{ {'order': #order} }",
        "timeoutMs": 5000,
        "memoryLimitMb": 64
      },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": "PT10S",
      "isStart": false,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [
        { "name": "legLines",       "javaClass": "java.util.List",   "defaultExpression": null, "required": false },
        { "name": "actualSequence", "javaClass": "java.util.List",   "defaultExpression": null, "required": false },
        { "name": "journeyType",    "javaClass": "java.lang.String", "defaultExpression": null, "required": false }
      ],
      "andJoin": false,
      "errorPolicy": { "retryCount": 1, "backoffMs": 200, "timeoutMs": 5000, "failFast": false, "continueOnError": false }
    },
    {
      "id": "evaluateLegSequence",
      "name": "Evaluate Leg Sequences decision table",
      "type": "tool",
      "pluginName": "AgentToolPlugin",
      "properties": {
        "toolName": "decisionTableEvaluate",
        "input": "#{ {'tableName': 'Leg Sequences', 'journeyType': #journeyType, 'actualSequence': #actualSequence} }"
      },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": "PT15S",
      "isStart": false,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [
        { "name": "legSequenceResult", "javaClass": "java.util.Map", "defaultExpression": null, "required": false }
      ],
      "andJoin": false,
      "errorPolicy": { "retryCount": 1, "backoffMs": 250, "timeoutMs": 10000, "failFast": false, "continueOnError": true }
    },
    {
      "id": "iterateServiceability",
      "name": "For each leg line (Serviceability)",
      "type": "foreach",
      "pluginName": null,
      "properties": {
        "collection": "#{#legLines}",
        "itemVar": "currentLegLine",
        "indexVar": "currentLegIndex",
        "maxIterations": 1000
      },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": null,
      "isStart": false,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [],
      "andJoin": false,
      "errorPolicy": { "retryCount": 0, "backoffMs": 0, "timeoutMs": null, "failFast": false, "continueOnError": false }
    },
    {
      "id": "callServiceability",
      "name": "Check Serviceability for one leg",
      "type": "tool",
      "pluginName": "AgentToolPlugin",
      "properties": {
        "toolName": "Serviceability",
        "input": "#{ {'originZip': #currentLegLine.Addresses?.^[AddressType == 'Origination']?.PostalCode, 'destinationZip': #currentLegLine.Addresses?.^[AddressType == 'Destination']?.PostalCode, 'originCountryCode': #currentLegLine.Addresses?.^[AddressType == 'Origination']?.CountryCode, 'destinationCountryCode': #currentLegLine.Addresses?.^[AddressType == 'Destination']?.CountryCode, 'custTrackingId': T(String).valueOf(#order.OrderIdentity)} }"
      },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": "PT15S",
      "isStart": false,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [
        { "name": "serviceabilityResult", "javaClass": "java.util.Map", "defaultExpression": null, "required": false }
      ],
      "andJoin": false,
      "errorPolicy": { "retryCount": 1, "backoffMs": 250, "timeoutMs": 10000, "failFast": false, "continueOnError": true }
    },
    {
      "id": "accumulateServiceability",
      "name": "Accumulate Serviceability per leg",
      "type": "tool",
      "pluginName": "CodeExecPlugin",
      "properties": {
        "language": "java",
        "code": "// Step 4 accumulator: append one entry per leg line. If origin or\n// destination is missing on the current leg, record a skipped entry\n// instead of dropping the leg silently. serviceabilityResults must end\n// up with exactly legLines.size() entries.\njava.util.List<Object> acc = new java.util.ArrayList<>();\nif (input.get(\"acc\") instanceof java.util.List<?> existing) {\n  for (Object o : existing) acc.add(o);\n}\njava.util.Map<String,Object> leg = (java.util.Map<String,Object>) input.get(\"leg\");\njava.util.Map<String,Object> svc = (java.util.Map<String,Object>) input.get(\"svc\");\njava.util.Map<String,Object> entry = new java.util.LinkedHashMap<>();\nentry.put(\"lineId\", leg == null ? null : leg.get(\"LineId\"));\nentry.put(\"itemCode\", leg == null ? null : leg.get(\"ItemCode\"));\nif (svc != null) {\n  Object exc = ((java.util.Map<String,Object>) svc.getOrDefault(\"PostalCodeException\", java.util.Map.of())).get(\"ExceptionType\");\n  entry.put(\"isServiceable\", exc == null || exc.toString().isBlank());\n  entry.put(\"exceptionType\", exc);\n  entry.put(\"status\", \"checked\");\n} else {\n  entry.put(\"status\", \"skipped\");\n  entry.put(\"reason\", \"missing addresses or Serviceability call failed\");\n}\nacc.add(entry);\nreturn acc;",
        "input": "#{ {'acc': #serviceabilityResults?.output, 'leg': #currentLegLine, 'svc': #serviceabilityResult} }",
        "timeoutMs": 5000,
        "memoryLimitMb": 64
      },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": "PT10S",
      "isStart": false,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [
        { "name": "serviceabilityResults", "javaClass": "java.util.List", "defaultExpression": null, "required": false }
      ],
      "andJoin": false,
      "errorPolicy": { "retryCount": 1, "backoffMs": 200, "timeoutMs": 5000, "failFast": false, "continueOnError": false }
    },
    {
      "id": "prepareContainerCheck",
      "name": "Prepare ContainerAvailability work queue (Step 5 filter)",
      "type": "tool",
      "pluginName": "CodeExecPlugin",
      "properties": {
        "language": "java",
        "code": "// Step 5: build toCheck = IDEL lines from order.Lines (NOT legLines)\n// that are missing ContainerId or ScheduledDate and have NOT already\n// been delivered. If toCheck is empty the foreach below naturally\n// produces zero invocations and containerAvailability stays empty.\njava.util.Map<String,Object> order = (java.util.Map<String,Object>) input.get(\"order\");\njava.util.List<java.util.Map<String,Object>> allLines =\n    (java.util.List<java.util.Map<String,Object>>) order.getOrDefault(\"Lines\", java.util.List.of());\njava.util.List<Object> toCheck = new java.util.ArrayList<>();\nfor (java.util.Map<String,Object> l : allLines) {\n  if (!\"IDEL\".equals(String.valueOf(l.get(\"ItemCode\")))) continue;\n  Object deliveryDate = l.get(\"DeliveryDate\");\n  if (deliveryDate != null && !deliveryDate.toString().isBlank()) continue;\n  Object containerId   = l.get(\"ContainerId\");\n  Object scheduledDate = l.get(\"ScheduledDate\");\n  boolean missing = (containerId == null || containerId.toString().isBlank())\n                 || (scheduledDate == null || scheduledDate.toString().isBlank());\n  if (missing) toCheck.add(l);\n}\nreturn toCheck;",
        "input": "#{ {'order': #order} }",
        "timeoutMs": 5000,
        "memoryLimitMb": 64
      },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": "PT10S",
      "isStart": false,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [
        { "name": "toCheck", "javaClass": "java.util.List", "defaultExpression": null, "required": false }
      ],
      "andJoin": false,
      "errorPolicy": { "retryCount": 1, "backoffMs": 200, "timeoutMs": 5000, "failFast": false, "continueOnError": false }
    },
    {
      "id": "iterateContainerAvailability",
      "name": "For each IDEL line (ContainerAvailability)",
      "type": "foreach",
      "pluginName": null,
      "properties": {
        "collection": "#{#toCheck}",
        "itemVar": "currentContainerLine",
        "indexVar": "currentContainerIndex",
        "maxIterations": 1000
      },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": null,
      "isStart": false,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [],
      "andJoin": false,
      "errorPolicy": { "retryCount": 0, "backoffMs": 0, "timeoutMs": null, "failFast": false, "continueOnError": false }
    },
    {
      "id": "callContainerAvailability",
      "name": "Check ContainerAvailability for one IDEL line",
      "type": "tool",
      "pluginName": "AgentToolPlugin",
      "properties": {
        "toolName": "ContainerAvailability",
        "input": "#{ {'zip': #currentContainerLine.Addresses?.^[AddressType == 'Origination']?.PostalCode, 'countryCode': #currentContainerLine.Addresses?.^[AddressType == 'Origination']?.CountryCode, 'siteIdentity': #currentContainerLine.AssignedSiteId, 'containerSize': #currentContainerLine.ContainerSize, 'referenceDate': (#currentContainerLine.ScheduledDate ?: T(java.time.LocalDate).now().toString()), 'custTrackingId': T(String).valueOf(#order.OrderIdentity)} }"
      },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": "PT15S",
      "isStart": false,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [
        { "name": "containerAvailabilityResult", "javaClass": "java.util.Map", "defaultExpression": null, "required": false }
      ],
      "andJoin": false,
      "errorPolicy": { "retryCount": 1, "backoffMs": 250, "timeoutMs": 10000, "failFast": false, "continueOnError": true }
    },
    {
      "id": "accumulateContainer",
      "name": "Accumulate ContainerAvailability per IDEL line",
      "type": "tool",
      "pluginName": "CodeExecPlugin",
      "properties": {
        "language": "java",
        "code": "// Step 5 accumulator: collect one entry per toCheck line.\njava.util.List<Object> acc = new java.util.ArrayList<>();\nif (input.get(\"acc\") instanceof java.util.List<?> existing) {\n  for (Object o : existing) acc.add(o);\n}\njava.util.Map<String,Object> line = (java.util.Map<String,Object>) input.get(\"line\");\njava.util.Map<String,Object> ca = (java.util.Map<String,Object>) input.get(\"ca\");\njava.util.Map<String,Object> entry = new java.util.LinkedHashMap<>();\nentry.put(\"lineId\", line == null ? null : line.get(\"LineId\"));\nentry.put(\"itemCode\", \"IDEL\");\nentry.put(\"checked\", ca != null);\njava.util.List<Object> availableDates = new java.util.ArrayList<>();\nif (ca != null) {\n  java.util.List<java.util.Map<String,Object>> dates =\n      (java.util.List<java.util.Map<String,Object>>) ca.getOrDefault(\"GeneralAvailabilityDates\", java.util.List.of());\n  for (java.util.Map<String,Object> d : dates) {\n    Object avail = d.get(\"IsAvailableCS\");\n    Object reason = d.get(\"ReasonCode\");\n    boolean isAvailable = Boolean.TRUE.equals(avail);\n    boolean noReason = (reason == null) || reason.toString().isBlank();\n    if (isAvailable && noReason) availableDates.add(d.get(\"DateValue\"));\n  }\n}\nentry.put(\"availableDates\", availableDates);\nacc.add(entry);\nreturn acc;",
        "input": "#{ {'acc': #containerAvailabilityResults?.output, 'line': #currentContainerLine, 'ca': #containerAvailabilityResult} }",
        "timeoutMs": 5000,
        "memoryLimitMb": 64
      },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": "PT10S",
      "isStart": false,
      "isEnd": false,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [
        { "name": "containerAvailabilityResults", "javaClass": "java.util.List", "defaultExpression": null, "required": false }
      ],
      "andJoin": false,
      "errorPolicy": { "retryCount": 1, "backoffMs": 200, "timeoutMs": 5000, "failFast": false, "continueOnError": false }
    },
    {
      "id": "end",
      "name": "End",
      "type": "route",
      "pluginName": null,
      "properties": {
        "result": "#{ {'orderId': #orderId, 'legSequence': #legSequenceResult, 'serviceability': (#serviceabilityResults?.output ?: {}), 'containerAvailability': (#containerAvailabilityResults?.output ?: {})} }"
      },
      "inputSchema": {},
      "outputSchema": {},
      "deadlineExpression": null,
      "isStart": false,
      "isEnd": true,
      "subflowDefId": null,
      "subflowInputs": {},
      "subflowOutputs": {},
      "outputVariables": [],
      "andJoin": false,
      "errorPolicy": { "retryCount": 0, "backoffMs": 0, "timeoutMs": null, "failFast": false, "continueOnError": false }
    }
  ],
  "transitions": [
    { "id": "t-start-fetchOrder",                "fromActivityId": "start",                       "toActivityId": "fetchOrder",                  "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",  "priority": null, "isDefault": false },
    { "id": "t-fetchOrder-prepareLegLines",      "fromActivityId": "fetchOrder",                  "toActivityId": "prepareLegLines",             "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",  "priority": null, "isDefault": false },
    { "id": "t-fetchOrder-err-end",              "fromActivityId": "fetchOrder",                  "toActivityId": "end",                         "condition": null, "isErrorEdge": true,  "matchesErrorClass": null, "trigger": "ON_ERROR",    "priority": 1,    "isDefault": false },
    { "id": "t-prepareLegLines-evaluate",        "fromActivityId": "prepareLegLines",             "toActivityId": "evaluateLegSequence",         "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",  "priority": null, "isDefault": false },
    { "id": "t-evaluate-iterServiceability",     "fromActivityId": "evaluateLegSequence",         "toActivityId": "iterateServiceability",       "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",  "priority": null, "isDefault": false },
    { "id": "t-iterServ-body",                   "fromActivityId": "iterateServiceability",       "toActivityId": "callServiceability",          "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",  "priority": null, "isDefault": false },
    { "id": "t-iterServ-exit",                   "fromActivityId": "iterateServiceability",       "toActivityId": "prepareContainerCheck",       "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_NO_MATCH", "priority": 100,  "isDefault": true  },
    { "id": "t-callServ-accumulate",             "fromActivityId": "callServiceability",          "toActivityId": "accumulateServiceability",    "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",  "priority": null, "isDefault": false },
    { "id": "t-accumServ-loop",                  "fromActivityId": "accumulateServiceability",    "toActivityId": "iterateServiceability",       "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",  "priority": null, "isDefault": false },
    { "id": "t-prepareContainer-iter",           "fromActivityId": "prepareContainerCheck",       "toActivityId": "iterateContainerAvailability","condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",  "priority": null, "isDefault": false },
    { "id": "t-iterContainer-body",              "fromActivityId": "iterateContainerAvailability","toActivityId": "callContainerAvailability",  "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",  "priority": null, "isDefault": false },
    { "id": "t-iterContainer-exit",              "fromActivityId": "iterateContainerAvailability","toActivityId": "end",                         "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_NO_MATCH", "priority": 100,  "isDefault": true  },
    { "id": "t-callContainer-accumulate",        "fromActivityId": "callContainerAvailability",   "toActivityId": "accumulateContainer",         "condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",  "priority": null, "isDefault": false },
    { "id": "t-accumContainer-loop",             "fromActivityId": "accumulateContainer",         "toActivityId": "iterateContainerAvailability","condition": null, "isErrorEdge": false, "matchesErrorClass": null, "trigger": "ON_SUCCESS",  "priority": null, "isDefault": false }
  ]
}
